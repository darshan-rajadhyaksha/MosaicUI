---
import BaseLayout from "@/layouts/base.astro";
import project from "@/config/project";
import getUrl from "@/lib/get-url";

import ChangeLog01March2026 from "@/changelogs/log-01-march-2026.mdx";
import ChangeLog03March2026 from "@/changelogs/log-03-march-2026.mdx";
import ChangeLog07March2026 from "@/changelogs/log-07-march-2026.mdx";
import ChangeLog08March2026 from "@/changelogs/log-08-march-2026.mdx";
import ChangeLog09March2026 from "@/changelogs/log-09-march-2026.mdx";
import ChangeLog10March2026 from "@/changelogs/log-10-march-2026.mdx";
import ChangeLog11March2026 from "@/changelogs/log-11-march-2026.mdx";
import ChangeLog13March2026 from "@/changelogs/log-13-march-2026.mdx";
import ChangeLog14March2026 from "@/changelogs/log-14-march-2026.mdx";
import ChangeLog15March2026 from "@/changelogs/log-15-march-2026.mdx";

const changelogs = [
	ChangeLog15March2026,
	ChangeLog14March2026,
	ChangeLog13March2026,
	ChangeLog11March2026,
	ChangeLog10March2026,
	ChangeLog09March2026,
	ChangeLog08March2026,
	ChangeLog07March2026,
	ChangeLog03March2026,
	ChangeLog01March2026,
];

const title = "Changelog";

const meta = {
	title: `${title} | ${project.name}`,
	image: getUrl(`assets/index.jpg`),
	url: getUrl("changelog/"),
};
---

<BaseLayout meta={meta}>
	<section>
		<h1>{title}</h1>
		<p>
			Explore the history of updates and ensure your project is leveraging the latest features.
		</p>
	</section>

	<section class="changelogs">
		{
			changelogs.map((ChangeLog) => (
				<div class="changelog">
					<ChangeLog />
				</div>
			))
		}
	</section>
</BaseLayout>

<style>
	.changelogs {
		margin-top: 8px;

		.changelog {
			margin-bottom: 48px;
			&:last-child {
				margin-bottom: 0;
			}
			h3 {
				margin: 8px 0;
			}
			p {
				margin: 8px 0;
			}
			ul {
				margin: 12px 0;
				padding-left: 32px;
				li {
					margin: 6px 0;
				}
			}
		}
	}
</style>
